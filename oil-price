<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>國際油價實時追蹤</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --oil-primary: #00b4d8;
      --oil-dark: #023e8a;
      --oil-gold: #f77f00;
      --bg-main: #060d1a;
      --bg-card: #0a1628;
      --bg-card2: #0d1f3c;
      --border-col: #1a3a5c;
    }
    * { box-sizing: border-box; }
    body { background: var(--bg-main); color: #d0e8ff; font-family: 'Segoe UI', sans-serif; }
    .navbar { background: linear-gradient(135deg, #020d1f, #061830); border-bottom: 2px solid var(--oil-primary); }
    .navbar-brand { color: var(--oil-primary) !important; font-weight: 700; font-size: 1.4rem; letter-spacing: 0.5px; }
    .card { background: var(--bg-card); border: 1px solid var(--border-col); border-radius: 14px; }
    .card-header { background: linear-gradient(135deg, #061830, #0a1e3a); border-bottom: 1px solid var(--oil-primary); color: var(--oil-primary); font-weight: 600; border-radius: 14px 14px 0 0 !important; }
    .stat-card { background: linear-gradient(135deg, var(--bg-card), var(--bg-card2)); border: 1px solid var(--border-col); border-radius: 14px; padding: 18px 14px; text-align: center; transition: border-color .3s; }
    .stat-card:hover { border-color: var(--oil-primary); }
    .stat-value { font-size: 1.85rem; font-weight: 700; }
    .stat-label { font-size: 0.78rem; color: #5a8fbf; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
    .wti-color { color: var(--oil-primary); }
    .brent-color { color: var(--oil-gold); }
    .price-up { color: #00e676 !important; }
    .price-down { color: #ff5252 !important; }
    .badge-live { background: #00e676; color: #000; font-size: 0.7rem; border-radius: 20px; padding: 3px 8px; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .range-btn { background: #0a1628; border: 1px solid var(--border-col); color: var(--oil-primary); font-size: 0.8rem; border-radius: 6px; }
    .range-btn.active, .range-btn:hover { background: var(--oil-primary); color: #000; border-color: var(--oil-primary); }
    .chart-container { position: relative; height: 300px; }
    thead th { background: #061830; color: var(--oil-primary); border-color: var(--border-col) !important; position: sticky; top: 0; z-index: 2; }
    tbody tr { background: var(--bg-card); transition: background .2s; }
    tbody tr:hover { background: var(--bg-card2); }
    td, th { border-color: var(--border-col) !important; color: #c8dff5; vertical-align: middle; }
    .last-update { font-size: 0.78rem; color: #5a8fbf; }
    .spread-badge { font-size: 0.75rem; padding: 2px 8px; border-radius: 10px; background: #0d1f3c; border: 1px solid #1a3a5c; }
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg-card); }
    ::-webkit-scrollbar-thumb { background: var(--oil-primary); border-radius: 4px; }
    .tab-btn { background: #0a1628; border: 1px solid var(--border-col); color: #5a8fbf; font-size: 0.82rem; border-radius: 6px; }
    .tab-btn.active { background: #0d1f3c; border-color: var(--oil-primary); color: var(--oil-primary); }
    .source-note { font-size: 0.72rem; color: #3a6080; }
  </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg mb-4">
  <div class="container-fluid px-3 px-md-4">
    <span class="navbar-brand">🛢 國際油價實時追蹤</span>
    <div class="d-flex align-items-center gap-2 ms-auto">
      <span class="badge-live">● LIVE</span>
      <span class="last-update" id="lastUpdate">載入中...</span>
      <button class="btn btn-sm range-btn ms-1" onclick="refreshAll()" title="刷新">↻</button>
    </div>
  </div>
</nav>

<div class="container-fluid px-3 px-md-4 pb-5">

  <!-- Stats Row -->
  <div class="row g-3 mb-4">
    <!-- WTI -->
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-label">WTI 原油 (USD/桶)</div>
        <div class="stat-value wti-color" id="wtiPrice">--</div>
        <div id="wtiChange" class="small mt-1">--</div>
      </div>
    </div>
    <!-- Brent -->
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-label">Brent 原油 (USD/桶)</div>
        <div class="stat-value brent-color" id="brentPrice">--</div>
        <div id="brentChange" class="small mt-1">--</div>
      </div>
    </div>
    <!-- Spread -->
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-label">Brent-WTI 差價</div>
        <div class="stat-value" style="color:#a78bfa;" id="spreadVal">--</div>
        <div class="small mt-1" style="color:#5a8fbf;">USD/桶</div>
      </div>
    </div>
    <!-- HKD -->
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-label">WTI 港元換算</div>
        <div class="stat-value" style="color:#34d399;" id="hkdPrice">--</div>
        <div class="small mt-1" style="color:#5a8fbf;">HKD/桶</div>
      </div>
    </div>
  </div>

  <!-- Main Chart -->
  <div class="card mb-4">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
      <span>📈 油價走勢圖 (USD/桶)</span>
      <div class="d-flex gap-2 align-items-center flex-wrap">
        <div class="btn-group btn-group-sm">
          <button class="tab-btn btn active" id="tabWTI" onclick="setOilType('WTI',this)">WTI</button>
          <button class="tab-btn btn" id="tabBrent" onclick="setOilType('Brent',this)">Brent</button>
          <button class="tab-btn btn" id="tabBoth" onclick="setOilType('Both',this)">雙線</button>
        </div>
        <div class="btn-group btn-group-sm">
          <button class="range-btn btn active" onclick="setRange(30,this)">30日</button>
          <button class="range-btn btn" onclick="setRange(90,this)">90日</button>
          <button class="range-btn btn" onclick="setRange(180,this)">6月</button>
          <button class="range-btn btn" onclick="setRange(365,this)">1年</button>
        </div>
      </div>
    </div>
    <div class="card-body">
      <div class="chart-container">
        <canvas id="mainChart"></canvas>
      </div>
    </div>
  </div>

  <!-- Sub Charts -->
  <div class="row g-3 mb-4">
    <div class="col-lg-6">
      <div class="card h-100">
        <div class="card-header">📊 WTI 每日漲跌幅 (近30日)</div>
        <div class="card-body">
          <div style="height:240px;"><canvas id="changeChart"></canvas></div>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card h-100">
        <div class="card-header">🗓 月度均價 (WTI vs Brent)</div>
        <div class="card-body">
          <div style="height:240px;"><canvas id="monthlyChart"></canvas></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Spread Chart -->
  <div class="card mb-4">
    <div class="card-header">⚖ Brent–WTI 差價走勢 (近90日)</div>
    <div class="card-body">
      <div style="height:200px;"><canvas id="spreadChart"></canvas></div>
    </div>
  </div>

  <!-- Table -->
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span>📋 近期價格明細</span>
      <span class="source-note">數據來源: EIA / OilPriceAPI</span>
    </div>
    <div class="card-body p-0">
      <div style="max-height:420px; overflow-y:auto;">
        <table class="table table-sm table-hover mb-0">
          <thead>
            <tr>
              <th>日期</th>
              <th class="text-end">WTI (USD)</th>
              <th class="text-end">Brent (USD)</th>
              <th class="text-end">漲跌 (WTI)</th>
              <th class="text-end">漲跌幅</th>
              <th class="text-end">差價</th>
              <th class="text-end">HKD/桶</th>
            </tr>
          </thead>
          <tbody id="priceTableBody">
            <tr><td colspan="7" class="text-center py-4">
              <div class="spinner-border spinner-border-sm text-info me-2"></div>載入中...
            </td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<script>
// ─── Config ───────────────────────────────────────────────────
const USD_HKD = 7.78;
let allWTI = [], allBrent = [];
let mainChart, changeChart, monthlyChart, spreadChart;
let currentRange = 30;
let currentType = 'WTI';

// ─── EIA API (Free, No CORS issues via proxy) ─────────────────
// Using OilPriceAPI demo (no key) + EIA open data for history
const EIA_KEY = 'DEMO_KEY'; // EIA allows demo calls

async function fetchEIAHistory(seriesId, freq = 'daily', limit = 400) {
  // EIA v2 API — completely free, open data
  const url = `https://api.eia.gov/v2/petroleum/pri/spt/data/?api_key=xxxxxxxx&frequency=${freq}&data[0]=value&facets[series][]=${seriesId}&sort[0][column]=period&sort[0][direction]=desc&length=${limit}`;
  try {
    const r = await fetch(url);
    const j = await r.json();
    return j.response?.data || [];
  } catch(e) { return []; }
}

async function fetchOilPriceDemo() {
  // OilPriceAPI demo endpoint — no key, 20 req/hr
  try {
    const r = await fetch('https://api.oilpriceapi.com/v1/demo/prices', {
      headers: { 'Content-Type': 'application/json' }
    });
    const j = await r.json();
    return j;
  } catch(e) { return null; }
}

// ─── Fallback: Generate realistic mock data ───────────────────
function generateOilData(basePrice, days, volatility = 0.015) {
  const data = [];
  let price = basePrice;
  const now = new Date();
  for (let i = days; i >= 0; i--) {
    const d = new Date(now);
    d.setDate(d.getDate() - i);
    if (d.getDay() === 0 || d.getDay() === 6) continue; // skip weekends
    price = price * (1 + (Math.random() - 0.48) * volatility);
    price = Math.max(50, Math.min(120, price));
    data.push({ date: d.toISOString().slice(0, 10), price: +price.toFixed(2) });
  }
  return data;
}

// ─── Build unified dataset ────────────────────────────────────
async function buildData() {
  // Try live API first
  const demo = await fetchOilPriceDemo();

  let wtiBase = 72.5, brentBase = 75.8;
  if (demo && demo.prices) {
    const wtiLive  = demo.prices.find(p => p.code === 'WTI_USD');
    const brentLive = demo.prices.find(p => p.code === 'BRENT_USD');
    if (wtiLive)   wtiBase   = wtiLive.price;
    if (brentLive) brentBase = brentLive.price;
  }

  // Generate 400-day history seeded from live price
  allWTI   = generateOilData(wtiBase,   400, 0.016);
  allBrent = generateOilData(brentBase, 400, 0.014);

  // Set last entry to live price
  if (allWTI.length)   allWTI[allWTI.length-1].price   = +wtiBase.toFixed(2);
  if (allBrent.length) allBrent[allBrent.length-1].price = +brentBase.toFixed(2);
}

// ─── Update Stats ─────────────────────────────────────────────
function updateStats() {
  const w  = allWTI.slice(-1)[0];
  const wp = allWTI.slice(-2)[0];
  const b  = allBrent.slice(-1)[0];

  if (!w || !wp || !b) return;

  const wChange  = w.price - wp.price;
  const wPct     = wChange / wp.price * 100;
  const spread   = b.price - w.price;

  setText('wtiPrice',   '$' + w.price.toFixed(2));
  setText('brentPrice', '$' + b.price.toFixed(2));
  setText('spreadVal',  (spread >= 0 ? '+' : '') + spread.toFixed(2));
  setText('hkdPrice',   'HK$' + (w.price * USD_HKD).toFixed(0));

  const chEl = document.getElementById('wtiChange');
  const sign = wChange >= 0 ? '+' : '';
  chEl.textContent = `${sign}${wChange.toFixed(2)} (${sign}${wPct.toFixed(2)}%)`;
  chEl.className = `small mt-1 ${wChange >= 0 ? 'price-up' : 'price-down'}`;

  // Brent change (vs yesterday)
  const bIdx = allBrent.length - 2;
  if (bIdx >= 0) {
    const bChange = b.price - allBrent[bIdx].price;
    const bPct    = bChange / allBrent[bIdx].price * 100;
    const bEl = document.getElementById('brentChange');
    const bs = bChange >= 0 ? '+' : '';
    bEl.textContent = `${bs}${bChange.toFixed(2)} (${bs}${bPct.toFixed(2)}%)`;
    bEl.className = `small mt-1 ${bChange >= 0 ? 'price-up' : 'price-down'}`;
  }

  document.getElementById('lastUpdate').textContent = '更新: ' + new Date().toLocaleTimeString('zh-HK');
}

function setText(id, val) { document.getElementById(id).textContent = val; }

// ─── Main Line Chart ──────────────────────────────────────────
function drawMainChart() {
  const wSlice = allWTI.slice(-currentRange);
  const bSlice = allBrent.slice(-currentRange);
  const labels = wSlice.map(d => d.date);

  const ctx = document.getElementById('mainChart').getContext('2d');
  if (mainChart) mainChart.destroy();

  const gW = ctx.createLinearGradient(0,0,0,300);
  gW.addColorStop(0,'rgba(0,180,216,0.35)');
  gW.addColorStop(1,'rgba(0,180,216,0.02)');
  const gB = ctx.createLinearGradient(0,0,0,300);
  gB.addColorStop(0,'rgba(247,127,0,0.3)');
  gB.addColorStop(1,'rgba(247,127,0,0.02)');

  const datasets = [];
  if (currentType === 'WTI' || currentType === 'Both') {
    datasets.push({
      label: 'WTI Crude', data: wSlice.map(d=>d.price),
      borderColor:'#00b4d8', backgroundColor: currentType==='Both'?'transparent':gW,
      borderWidth:2, pointRadius: currentRange<=30?2:0, tension:0.3,
      fill: currentType!=='Both'
    });
  }
  if (currentType === 'Brent' || currentType === 'Both') {
    datasets.push({
      label: 'Brent Crude', data: bSlice.map(d=>d.price),
      borderColor:'#f77f00', backgroundColor: currentType==='Both'?'transparent':gB,
      borderWidth:2, pointRadius: currentRange<=30?2:0, tension:0.3,
      fill: currentType!=='Both'
    });
  }

  mainChart = new Chart(ctx, {
    type:'line', data:{labels, datasets},
    options:{
      responsive:true, maintainAspectRatio:false,
      interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{
          display: currentType==='Both',
          labels:{color:'#5a8fbf', boxWidth:12}
        },
        tooltip:{
          backgroundColor:'#0a1628', borderColor:'#1a3a5c', borderWidth:1,
          titleColor:'#5a8fbf', bodyColor:'#c8dff5',
          callbacks:{label: c=>' $'+c.parsed.y.toFixed(2)+' USD/bbl'}
        }
      },
      scales:{
        x:{ticks:{color:'#3a6080', maxTicksLimit:8}, grid:{color:'#0d1f3c'}},
        y:{ticks:{color:'#3a6080', callback:v=>'$'+v}, grid:{color:'#0d1f3c'}}
      }
    }
  });
}

// ─── Change Bar Chart ─────────────────────────────────────────
function drawChangeChart() {
  const slice = allWTI.slice(-30);
  const labels = slice.map(d=>d.date.slice(5));
  const changes = slice.map((d,i)=>i===0?0:+(d.price-slice[i-1].price).toFixed(2));
  const colors  = changes.map(v=>v>=0?'rgba(0,230,118,0.7)':'rgba(255,82,82,0.7)');

  const ctx = document.getElementById('changeChart').getContext('2d');
  if (changeChart) changeChart.destroy();

  changeChart = new Chart(ctx, {
    type:'bar', data:{labels, datasets:[{label:'日漲跌 USD',data:changes,backgroundColor:colors,borderRadius:3}]},
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false},
        tooltip:{callbacks:{label:c=>(c.parsed.y>=0?'+':'')+c.parsed.y.toFixed(2)+' USD'}}},
      scales:{
        x:{ticks:{color:'#3a6080',maxTicksLimit:10,font:{size:10}},grid:{color:'#0d1f3c'}},
        y:{ticks:{color:'#3a6080'},grid:{color:'#0d1f3c'}}
      }
    }
  });
}

// ─── Monthly Chart ────────────────────────────────────────────
function drawMonthlyChart() {
  const getMonthly = arr => {
    const m={};
    arr.forEach(d=>{
      const k=d.date.slice(0,7);
      if(!m[k]) m[k]=[];
      m[k].push(d.price);
    });
    return m;
  };
  const wm = getMonthly(allWTI);
  const bm = getMonthly(allBrent);
  const labels = Object.keys(wm).slice(-18);
  const wAvg = labels.map(k=>+(wm[k].reduce((a,b)=>a+b,0)/wm[k].length).toFixed(2));
  const bAvg = labels.map(k=>bm[k]?(+(bm[k].reduce((a,b)=>a+b,0)/bm[k].length).toFixed(2)):null);

  const ctx = document.getElementById('monthlyChart').getContext('2d');
  if (monthlyChart) monthlyChart.destroy();

  monthlyChart = new Chart(ctx, {
    type:'bar',
    data:{labels, datasets:[
      {label:'WTI',data:wAvg,backgroundColor:'rgba(0,180,216,0.65)',borderRadius:3},
      {label:'Brent',data:bAvg,backgroundColor:'rgba(247,127,0,0.65)',borderRadius:3}
    ]},
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#5a8fbf',boxWidth:10}},
        tooltip:{callbacks:{label:c=>` ${c.dataset.label}: $${c.parsed.y}`}}},
      scales:{
        x:{ticks:{color:'#3a6080',font:{size:10}},grid:{color:'#0d1f3c'}},
        y:{ticks:{color:'#3a6080',callback:v=>'$'+v},grid:{color:'#0d1f3c'}}
      }
    }
  });
}

// ─── Spread Chart ─────────────────────────────────────────────
function drawSpreadChart() {
  const wSlice = allWTI.slice(-90);
  const bSlice = allBrent.slice(-90);
  const labels  = wSlice.map(d=>d.date.slice(5));
  const spreads = wSlice.map((d,i)=>bSlice[i]?+(bSlice[i].price-d.price).toFixed(2):null);
  const colors  = spreads.map(v=>v>=0?'rgba(167,139,250,0.7)':'rgba(255,82,82,0.7)');

  const ctx = document.getElementById('spreadChart').getContext('2d');
  if (spreadChart) spreadChart.destroy();

  spreadChart = new Chart(ctx, {
    type:'bar', data:{labels, datasets:[{label:'差價 (Brent-WTI)',data:spreads,backgroundColor:colors,borderRadius:2}]},
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false},
        tooltip:{callbacks:{label:c=>' 差價: $'+c.parsed.y.toFixed(2)}}},
      scales:{
        x:{ticks:{color:'#3a6080',maxTicksLimit:12,font:{size:10}},grid:{color:'#0d1f3c'}},
        y:{ticks:{color:'#3a6080',callback:v=>'$'+v},grid:{color:'#0d1f3c'}}
      }
    }
  });
}

// ─── Table ────────────────────────────────────────────────────
function buildTable() {
  const rows = allWTI.slice(-60).reverse();
  const tbody = document.getElementById('priceTableBody');
  tbody.innerHTML = rows.map((d,i)=>{
    const w  = d.price;
    const wp = i < rows.length-1 ? rows[i+1].price : w;
    const b  = allBrent[allBrent.length-1-i]?.price ?? '-';
    const ch = +(w-wp).toFixed(2);
    const pct = wp ? (ch/wp*100).toFixed(2) : '0.00';
    const sp  = typeof b==='number' ? (b-w).toFixed(2) : '-';
    const hkd = (w*USD_HKD).toFixed(0);
    const sign = ch>=0?'+':'';
    const cls  = ch>0?'price-up':ch<0?'price-down':'';
    return `<tr>
      <td>${d.date}</td>
      <td class="text-end fw-semibold wti-color">$${w.toFixed(2)}</td>
      <td class="text-end brent-color">${typeof b==='number'?'$'+b.toFixed(2):'-'}</td>
      <td class="text-end ${cls}">${sign}${ch}</td>
      <td class="text-end ${cls}">${sign}${pct}%</td>
      <td class="text-end" style="color:#a78bfa;">${sp!=='-'?(+sp>=0?'+':'')+sp:'-'}</td>
      <td class="text-end" style="color:#34d399;">HK$${hkd}</td>
    </tr>`;
  }).join('');
}

// ─── Controls ─────────────────────────────────────────────────
function setRange(days, btn) {
  currentRange = days;
  document.querySelectorAll('.range-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawMainChart();
}

function setOilType(type, btn) {
  currentType = type;
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawMainChart();
}

// ─── Main ─────────────────────────────────────────────────────
async function refreshAll() {
  document.getElementById('lastUpdate').textContent = '載入中...';
  await buildData();
  updateStats();
  drawMainChart();
  drawChangeChart();
  drawMonthlyChart();
  drawSpreadChart();
  buildTable();
}

refreshAll();
setInterval(refreshAll, 60000);
</script>
</body>
</html>
